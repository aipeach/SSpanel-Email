# 管理员登录（推荐配置 hash）
ADMIN_PASSWORD_HASH=
# 临时明文密码（仅当未配置 ADMIN_PASSWORD_HASH 时使用）
ADMIN_PASSWORD=

# 会话签名密钥（至少 32 位随机字符串）
# openssl rand -base64 48
SESSION_SECRET=

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=sspanel

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=SSPanel

# 异步队列（SQLite）
QUEUE_SQLITE_PATH=./data/email-queue.sqlite

# 默认发送速率（封/分钟）
DEFAULT_SEND_RATE_PER_MINUTE=60
